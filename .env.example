# EcoTrace environment variables.
#
# Copy this file to `.env` and fill in values only for the features you want
# enabled. `.env` is git-ignored and must never be committed.
#
# The app runs fully without a Gemini key: AI insights and chat fall back to
# deterministic local coaching. The key only enables live Gemini responses.

# Live Gemini-powered AI insights + chat.
# Get a key at aistudio.google.com (Google AI Studio) -> "Get API key".
# This is read ONLY on the server (App Router route handlers); it is never
# exposed to the client and must never be renamed to NEXT_PUBLIC_*.
GEMINI_API_KEY=
